generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Hazard {
  id          String   @id @default(cuid())
  type        String
  title       String
  description String
  lat         Float
  lng         Float
  prefecture  String?
  dangerLevel Int
  status      String   @default("active")
  occurredAt  DateTime
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
